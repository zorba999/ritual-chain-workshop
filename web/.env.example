# --- AI Bounty Judge / Ritual Chain ---
# Copy this file to `.env.local` and fill in the values.

# Deployed CommitRevealAIJudge contract address (0x...).
# A live demo deployment on Ritual Chain is available at:
NEXT_PUBLIC_CONTRACT_ADDRESS=0x93fec7789231ffdc05d7adbba8742f26b3d53337

# Ritual Chain JSON-RPC endpoint
NEXT_PUBLIC_RITUAL_RPC_URL=https://rpc.ritualfoundation.org

# Ritual Chain numeric chain id
NEXT_PUBLIC_RITUAL_CHAIN_ID=1979

# Ritual LLM executor / precompile-callback address used when building the
# `judgeAll` LLM request. Placeholder is fine for local UI development.
NEXT_PUBLIC_RITUAL_EXECUTOR_ADDRESS=0xB42e435c4252A5a2E7440e37B609F00c61a0c91B

# Optional: WalletConnect project id. Leave empty to use injected wallets only.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=219254c3130109ce4a7da6b7ce31982f
